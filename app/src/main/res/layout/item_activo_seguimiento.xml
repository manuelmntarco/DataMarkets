<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="?attr/selectableItemBackground">

    <!-- Columna izquierda: símbolo y nombre -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSimbolo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BTC"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#0C447C" />

        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Bitcoin"
            android:textSize="13sp"
            android:textColor="#888780" />

    </LinearLayout>

    <!-- Columna central: precio y variación -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvPrecio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="60.886 €"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1a1a1a" />

        <TextView
            android:id="@+id/tvVariacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="▲ +1,25%"
            android:textSize="13sp"
            android:textColor="#0F6E56" />

    </LinearLayout>

    <!-- Botón eliminar favorito -->
    <ImageButton
        android:id="@+id/btnEliminar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Eliminar favorito"
        android:alpha="0.4" />

</LinearLayout>