<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".ui.mercados.MercadosFragment">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingTop="20dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/contenedorFiltros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnTodas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/fondo_boton_inactivo"
                android:textColor="@color/black"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Todas"
                android:textSize="14sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/btnGanadoras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/fondo_boton_inactivo"
                android:textColor="@color/black"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:drawableStart="@drawable/ic_trending_up"
                android:drawablePadding="4dp"
                android:drawableTint="@color/azul_primario"
                android:text="Ganadoras"
                android:textSize="14sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/btnPerdedoras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/fondo_boton_inactivo"
                android:textColor="@color/black"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:drawableStart="@drawable/ic_trending_down"
                android:drawablePadding="4dp"
                android:drawableTint="@color/azul_primario"
                android:text="Perdedoras"
                android:textSize="14sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/btnTopCap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_boton_inactivo"
                android:textColor="@color/black"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:drawableStart="@drawable/ic_star"
                android:drawablePadding="4dp"
                android:drawableTint="@color/azul_primario"
                android:text="Top Cap"
                android:textSize="14sp"
                android:gravity="center" />

        </LinearLayout>
    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerActivos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/item_activo" />

</LinearLayout>